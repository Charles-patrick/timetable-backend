# Server
PORT=5000
NODE_ENV=development

# Database (MongoDB Atlas connection string)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/timetable-system

# Auth
JWT_SECRET=replace_this_with_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS - your Next.js frontend origin
FRONTEND_URL=http://localhost:3000

# Used only by scripts/seedAdmin.js to create the first admin account
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@timetable.edu
ADMIN_PASSWORD=ChangeThisPassword123!
